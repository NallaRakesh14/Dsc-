#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    float arr[] = {0.4, 0.2, 0.5, 0.1, 0.3};
    int n = 5;

    vector<float> b[5];

    for (int i = 0; i < n; i++) {
        int idx = arr[i] * n;
        b[idx].push_back(arr[i]);
    }

    for (int i = 0; i < n; i++)
        sort(b[i].begin(), b[i].end());

    int k = 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < b[i].size(); j++) {
            arr[k++] = b[i][j];
        }
    }

    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";

    return 0;
}
